# =============================================================================
# Estud-IA — .gitignore
# =============================================================================


# -----------------------------------------------------------------------------
# DATOS DE ALUMNOS
# Nunca deben versionarse — contienen información sensible de estudiantes
# -----------------------------------------------------------------------------
data/
*.csv
!test*.csv
*.xlsx
!test.xlsx
*.xls
uploads/
reports/
output/
*.pdf


# -----------------------------------------------------------------------------
# CREDENCIALES Y SECRETOS
# -----------------------------------------------------------------------------
# Archivos de entorno (el .example sí se versiona como plantilla)
.env
.env.*
!.env.example

# Carpetas de secretos y credenciales
secrets/
credentials/

# Archivos JSON con credenciales de Google Cloud / Service Accounts
# (se excluyen archivos de configuración de Node.js)
*.json
!package.json
!package-lock.json
service_account*.json
gcp_credentials*.json
adc.json


# -----------------------------------------------------------------------------
# GOOGLE CLOUD / VERTEX AI / ADK
# -----------------------------------------------------------------------------
application_default_credentials.json
.config/gcloud/
vertexai_cache/


# -----------------------------------------------------------------------------
# ENTORNO DE PYTHON
# -----------------------------------------------------------------------------
# Entornos virtuales
venv/
.venv/
env/
ENV/

# Cache de Python
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo

# Distribuciones y paquetes
*.egg
*.egg-info/
dist/
build/
wheels/

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json

# Testing
.pytest_cache/
.coverage
htmlcov/

# Jupyter (los checkpoints pueden contener datos)
.ipynb_checkpoints/
*.ipynb


# -----------------------------------------------------------------------------
# SISTEMA OPERATIVO
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini
*~


# -----------------------------------------------------------------------------
# EDITORES E IDEs
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace


# -----------------------------------------------------------------------------
# LOGS Y ARCHIVOS TEMPORALES
# -----------------------------------------------------------------------------
logs/
*.log
*.tmp
*.bak
*.orig
temp/
tmp/
