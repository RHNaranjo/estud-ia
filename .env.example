# =============================================================================
# Estud-IA — Variables de Entorno (PLANTILLA)
# =============================================================================
# Este archivo es una PLANTILLA. Copia este archivo como `.env` y reemplaza
# cada valor con tus credenciales reales. NUNCA subas `.env` al repositorio.
#
# Uso:
#   cp .env.example .env
# =============================================================================


# -----------------------------------------------------------------------------
# GEMINI API (Google AI Studio)
# Obtén tu API Key en: https://aiskudio.google.com/apikey
# Requerido para ejecutar los agentes con gemini-2.5-flash
# -----------------------------------------------------------------------------
GOOGLE_API_KEY=your_google_api_key_here


# -----------------------------------------------------------------------------
# GOOGLE ADK — Modelo por defecto
# Especifica el modelo de Gemini que usarán los agentes.
# Opciones recomendadas: gemini-2.5-flash  |  gemini-2.5-pro
# -----------------------------------------------------------------------------
ADK_MODEL=gemini-2.5-flash


# -----------------------------------------------------------------------------
# GOOGLE CLOUD (Opcional — sólo si usas Vertex AI en lugar de AI Studio)
# Necesario para entornos de producción o acceso corporativo.
# Documentación: https://cloud.google.com/vertex-ai/docs/start/client-libraries
# -----------------------------------------------------------------------------
# GOOGLE_CLOUD_PROJECT=your_gcp_project_id
# GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=./credentials/service_account.json


# -----------------------------------------------------------------------------
# CONFIGURACIÓN DE LA APLICACIÓN
# -----------------------------------------------------------------------------
# Entorno de ejecución: development | production
APP_ENV=development

# Número máximo de tokens en la respuesta de los agentes
ADK_MAX_OUTPUT_TOKENS=8192

# Temperatura del modelo (0.0 = determinista, 1.0 = más creativo)
ADK_TEMPERATURE=0.3

# Tamaño máximo permitido para archivos CSV subidos (en MB)
MAX_UPLOAD_SIZE_MB=10
